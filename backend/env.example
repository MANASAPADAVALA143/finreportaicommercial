# FinReport AI - Environment Configuration
# Copy to backend/.env for overrides. With no .env, the app uses SQLite + dev defaults.
# If the API hangs or never starts: switch DATABASE_URL to sqlite (above) or start Postgres.

# App Settings
APP_NAME=FinReport AI
VERSION=1.0.0
DEBUG=True
# Production (Railway): DEBUG=False

# Database (stateful R2R uses this for companies, journal_history, company_profiles, scoring_results)
# Production: AWS RDS (all client data). Supabase = auth only.
# DATABASE_URL=postgresql://USER:PASS@estatecfo.c3ma0ssuch0u.us-west-1.rds.amazonaws.com:5432/finreportai
DATABASE_URL=sqlite:///./finreportai.db

# production | demo — demo blocks writes and pins demo tenant
ENVIRONMENT=production
DEMO_TENANT_ID=00000000-0000-4000-8000-000000000001

# Supabase (optional locally — leave empty unless you use /api/v1/auth)
SUPABASE_URL=
SUPABASE_KEY=
# Direct Postgres URI — run python scripts/bootstrap_ap_supabase.py (or POST /api/ap/bootstrap-supabase-tables)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:5432/postgres
# N8N_WEBHOOK_URL=   # fallback when app_settings table missing
# N8N_CLASSIFY_JSON_URL=
# N8N_ASP_WEBHOOK_URL=   # n8n trigger for e-invoicing ASP submit/redrive
# GULFTAX_ASP_WEBHOOK_URL=   # alias for N8N_ASP_WEBHOOK_URL
# AP_ZOHO_REDIRECT_URI=http://localhost:8000/api/ap/integrations/zoho/callback
# AP_QBO_REDIRECT_URI=http://localhost:8000/api/ap/integrations/qbo/callback

# Inbound demo + VAPI speed-to-lead (POST /api/voice/inbound-lead; requires Supabase table inbound_leads — see backend/supabase_sql/inbound_leads.sql)
# Outbound call API: https://docs.vapi.ai/calls/outbound-calling  (POST https://api.vapi.ai/call)
VAPI_API_KEY=
NOVA_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=
# Optional: n8n (or similar) webhook — JSON POST on VAPI failure so you can email Manasa
INBOUND_LEAD_VAPI_FAILURE_WEBHOOK=

# Nova (VAPI dashboard): when SOURCE=web_form and KNOWN_PAIN is set, open with:
# "Hi {{PROSPECT_NAME}}, this is Nova from FinReportAI. You just requested a demo on our site —
# you mentioned {{KNOWN_PAIN}} is your biggest challenge right now. I want to make sure I understand
# your full situation before connecting you with Manasa. Is now a good time?"
# For cold outbound, set SOURCE to outbound in your n8n/VAPI campaign and use your standard opening.

# IFRS trial-balance upload (multipart): optional Form fields
#   currency=INR|USD|GBP|EUR  (omit to auto-detect from filename + first 3 rows)
#   auto_map=false             (skip background AI map; use POST .../map-with-ai once)

# Claude API
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI (optional — pgvector RAG embeddings only; main LLM is Anthropic/Bedrock)
OPENAI_API_KEY=
# Optional: OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional model overrides:
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_GL_MAPPING_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_EXCEL_ANALYZE_MODEL=claude-sonnet-4-20250514

# MCP: auto-generated tools from FastAPI at /mcp (Cowork / Claude Desktop connectors)
# ENABLE_FASTAPI_MCP=False
# Optional: when set, only requests to /mcp* must include header X-API-Key (does not affect /excel, /api, etc.)
# CLIENT_API_KEY=

# Security (override in production)
SECRET_KEY=your-super-secret-key-change-this-to-something-random-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Frontend URLs - include the port your frontend uses)
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3002","http://localhost:3006","http://localhost:5173"]
# Production: set to your Vercel URL (also allows custom domain in CORS)
# FRONTEND_URL=https://your-project.vercel.app

# Tally Windows connector (POST /api/erp/tally/connector-sync)
# Register rows in connector_clients: entity_id (unique), tenant_id, api_key_sha256 (hex of SHA-256 of plaintext key).
# Optional dev-only bypass so you can test without DB row (same length as key for compare_digest):
# TALLY_CONNECTOR_BYPASS_KEY=your-dev-plaintext-key
# TALLY_CONNECTOR_BYPASS_TENANT=default


