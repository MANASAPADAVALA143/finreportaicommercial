# FinReport AI - Environment Configuration

# App Settings
APP_NAME=FinReport AI
VERSION=1.0.0
DEBUG=True

# Database (stateful R2R uses this for companies, journal_history, company_profiles, scoring_results)
# For local dev without Postgres use: DATABASE_URL=sqlite:///./finreportai.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finreportai

# AI provider: anthropic (default) or gemini
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional overrides:
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# For Gemini instead: AI_PROVIDER=gemini  GOOGLE_API_KEY=your-google-ai-key  GEMINI_MODEL=gemini-1.5-flash

# AWS (optional — Transcribe + Polly for voice upload / TTS only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Security (REQUIRED - Generate a secure random key)
SECRET_KEY=your-super-secret-key-change-this-to-something-random-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (Frontend URLs - include the port your frontend uses)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3002", "http://localhost:5173"]


