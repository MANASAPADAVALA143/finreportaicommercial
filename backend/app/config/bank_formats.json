{
  "HDFC": {
    "keywords": ["hdfc", "hdfc bank"],
    "date_fmt": "\\d{2}/\\d{2}/\\d{2,4}",
    "pdf_cols": {
      "date": 0, "narration": 1, "debit": 4, "credit": 5, "balance": 6
    },
    "csv_cols": {
      "date":     ["Date", "Value Date", "Txn Date"],
      "narration": ["Narration", "Description", "Particulars"],
      "debit":    ["Withdrawal Amt.", "Withdrawal Amt", "Debit Amount", "DR"],
      "credit":   ["Deposit Amt.", "Deposit Amt", "Credit Amount", "CR"],
      "balance":  ["Closing Balance", "Balance"]
    }
  },
  "ICICI": {
