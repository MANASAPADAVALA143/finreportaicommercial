{
  "info": {
    "name": "FinReport AI Commercial API",
    "description": "Complete API collection for FinReport AI Commercial Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securepassword123\",\n  \"full_name\": \"John Doe\",\n  \"company\": \"Example Corp\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"securepassword123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"access_token\", jsonData.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Journal Entries",
      "item": [
        {
          "name": "Create Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry_date\": \"2024-01-15T10:00:00Z\",\n  \"description\": \"Office supplies purchase\",\n  \"account\": \"Office Expenses\",\n  \"debit\": 500.00,\n  \"credit\": 0.00,\n  \"reference\": \"INV-2024-001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/journal-entries/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "journal-entries", ""]
            }
          }
        },
        {
          "name": "Get All Entries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/journal-entries/?skip=0&limit=100",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "journal-entries", ""],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Get Entry by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/journal-entries/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "journal-entries", "1"]
            }
          }
        },
        {
          "name": "Approve Entry",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/journal-entries/1/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "journal-entries", "1", "approve"]
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/dashboard",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "dashboard"]
            }
          }
        },
        {
          "name": "Get Trends",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/trends?days=30",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "trends"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            }
          }
        },
        {
          "name": "Financial Ratios",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/financial-ratios",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "financial-ratios"]
            }
          }
        },
        {
          "name": "Get Anomalies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/analytics/anomalies?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "analytics", "anomalies"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Amazon Nova AI",
      "item": [
        {
          "name": "Analyze with Nova",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Analyze my Q4 financial performance and provide recommendations\",\n  \"context\": {\n    \"revenue\": 500000,\n    \"expenses\": 350000,\n    \"growth_rate\": 15\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/nova/analyze",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "nova", "analyze"]
            }
          }
        },
        {
          "name": "Analyze Journal Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry_date\": \"2024-01-15T10:00:00Z\",\n  \"description\": \"Large cash withdrawal\",\n  \"account\": \"Petty Cash\",\n  \"debit\": 9999.00,\n  \"credit\": 0.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/nova/analyze-entry",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "nova", "analyze-entry"]
            }
          }
        },
        {
          "name": "Generate Forecast",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthly_revenue\": [100000, 110000, 105000, 120000],\n  \"monthly_expenses\": [70000, 72000, 68000, 75000]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/nova/forecast?period=next_quarter",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "nova", "forecast"],
              "query": [
                {
                  "key": "period",
                  "value": "next_quarter"
                }
              ]
            }
          }
        },
        {
          "name": "Compliance Check",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"revenue_recognition\": \"point_in_time\",\n  \"depreciation_method\": \"straight_line\",\n  \"inventory_valuation\": \"fifo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/nova/compliance-check?standard=IFRS",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "nova", "compliance-check"],
              "query": [
                {
                  "key": "standard",
                  "value": "IFRS"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Root",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    }
  ]
}
