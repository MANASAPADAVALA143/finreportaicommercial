{
  "name": "finreportai-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "sync:addin": "node scripts/sync-addin.js",
    "dev:addin": "npm run sync:addin && npm run dev",
    "dev": "vite",
    "dev:help": "node -e \"console.log(['Backend (separate terminal): cd ../backend  then  python -m uvicorn app.main:app --reload --port 8000','Frontend: npm run dev  (http://localhost:3006)','Office add-in: npm run dev:addin  (copies excel-addin → public/addin then Vite)','frontend/.env: VITE_API_URL=http://localhost:8000','backend/.env: ANTHROPIC_API_KEY=sk-ant-...'].join('\\n'))\"",
    "build": "vite build",
    "build:deploy": "vite build --mode github-pages",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "predeploy": "npm run build:deploy",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@supabase/supabase-js": "^2.39.3",
    "axios": "^1.6.5",
    "clsx": "^2.1.0",
    "date-fns": "^3.0.6",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.309.0",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.21.0",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.2.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11"
  }
}
