{
  "name": "finreportai-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "sync:addin": "node scripts/sync-addin.js",
    "dev:addin": "npm run sync:addin && npm run dev",
    "dev": "vite",
    "dev:help": "node -e \"console.log(['Backend (separate terminal): cd ../backend  then  python -m uvicorn app.main:app --reload --port 8000','Frontend: npm run dev  (http://localhost:3006)','Office add-in: npm run dev:addin  (copies excel-addin → public/addin then Vite)','frontend/.env: VITE_API_URL=http://localhost:8000','backend/.env: ANTHROPIC_API_KEY=sk-ant-...'].join('\\n'))\"",
    "build": "vite build",
    "build:deploy": "vite build --mode github-pages",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "predeploy": "npm run build:deploy",
    "deploy": "gh-pages -d dist"
  },
