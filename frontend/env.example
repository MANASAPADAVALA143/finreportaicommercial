# Copy to frontend/.env
# Vite dev server: http://localhost:3006 (or next free port if 3006 is busy).
# Start API first: from backend/ run  uvicorn app.main:app --reload --port 8000
# All in-app LLM (TB commentary, pattern Nova text, etc.) uses backend Anthropic — no Gemini key needed.

VITE_API_URL=http://localhost:8000
