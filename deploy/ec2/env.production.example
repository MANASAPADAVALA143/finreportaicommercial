# Copy to /home/ubuntu/finreportaicommercial/backend/.env on EC2
# NEVER commit this file with real secrets.

DEBUG=False
ENVIRONMENT=production
SECRET_KEY=change-me-min-32-random-chars

# AWS RDS — use postgresql:// (SQLAlchemy + psycopg2-binary)
DATABASE_URL=postgresql://estatecfo_master:YOUR_RDS_PASSWORD@estatecfo.c3ma0ssuch0u.us-west-1.rds.amazonaws.com:5432/finreportai

ANTHROPIC_API_KEY=sk-ant-...

# Supabase — AUTH ONLY (service role for backend JWT verify + admin user create)
SUPABASE_URL=https://ftlycgfgbboxapxhlpad.supabase.co
SUPABASE_KEY=your-service-role-key-not-anon

# Optional: direct Postgres for audit/bootstrap scripts
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[pass]@...pooler.supabase.com:5432/postgres

# AWS S3 file uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-1
